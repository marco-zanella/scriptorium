# Copy to .env and adjust as needed. .env is gitignored.
# app/core/config.py has no defaults of its own — this file is the single
# source of truth, for both the venv-run app (which reads it directly, cwd
# must be the repo root) and docker-compose (variable substitution below).
#
# POSTGRES_HOST=localhost is correct for the local venv workflow (Postgres
# runs in Docker, exposed on the host at POSTGRES_PORT). If/when the api
# service is run via docker-compose instead (e.g. later deploy), compose
# overrides POSTGRES_HOST to the "postgres" service name for that container
# only — see docker-compose.yml.

POSTGRES_USER=scriptorium
POSTGRES_PASSWORD=scriptorium
POSTGRES_DB=scriptorium
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX_PREFIX=

API_HOST=localhost
API_PORT=8000
ROOT_PATH=

JWT_SECRET_KEY=

# openrouter or ollama. Use ollama locally - see below for why it must talk to
# Ollama's native /api/chat rather than its OpenAI-compat endpoint.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
# Only needed when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Only needed when LLM_PROVIDER=ollama. Must support tool/function calling
# (e.g. llama3.1, qwen2.5) - pull it first with `ollama pull <model>`.
OLLAMA_BASE_URL=http://localhost:11434
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
RAG_MAX_TOOL_ITERATIONS=5
